Cell[CellGroupData[{

Cell["Folding Numbers for Well-conditioned MPF", "Section",
 CellChangeTimes->{{3.9730701600266123`*^9, 3.973070178921062*^9}, {
  3.973108085517406*^9, 3.973108096719655*^9}, {3.989003878362012*^9, 
  3.989003893447837*^9}},ExpressionUUID->"6d33aa59-2e2b-416e-ae2b-\
e6c1ad4e741a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"coeffs", "[", 
    RowBox[{"m_", "?", "ListQ"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Inverse", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"VandermondeMatrix", "@", 
       RowBox[{"(", 
        RowBox[{"m", "^", 
         RowBox[{"(", 
          RowBox[{"-", "2"}], ")"}]}], ")"}]}], "]"}], "]"}], ".", 
    RowBox[{"ReplacePart", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"Length", "[", "m", "]"}]}], "]"}], ",", 
      RowBox[{"1", "->", "1"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"onenorm", "[", 
    RowBox[{"m_", "?", "ListQ"}], "]"}], ":=", 
   RowBox[{"Plus", "@@", 
    RowBox[{"(", 
     RowBox[{"Abs", "[", 
      RowBox[{"coeffs", "[", "m", "]"}], "]"}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.973070220054274*^9, 3.9730702221026497`*^9}, {
   3.973070267406042*^9, 3.9730702846176567`*^9}, {3.9730703161642733`*^9, 
   3.973070343724718*^9}, 3.973070382487418*^9, {3.9730704133420353`*^9, 
   3.97307048613065*^9}, {3.973070536340173*^9, 3.9730705616313467`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"6c6eb16f-ac44-4c3f-8677-75342efd5c57"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"wellcondsets", "[", 
    RowBox[{"thresh_", ",", "totnum_", ",", "motherset_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"subsets", ",", "i", ",", "wellnums", ",", "sortedwellnums"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"subsets", "=", 
       RowBox[{"Subsets", "[", 
        RowBox[{"motherset", ",", 
         RowBox[{"{", "totnum", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"wellnums", "=", 
       RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", 
         RowBox[{"Length", "[", "subsets", "]"}]}], ",", 
        RowBox[{"i", "++"}], ",", " ", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "[", 
            RowBox[{"onenorm", "[", 
             RowBox[{"subsets", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], "<", "thresh"}], ",",
           " ", 
          RowBox[{
           RowBox[{"wellnums", "[", 
            RowBox[{"subsets", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}], "=", 
           RowBox[{"N", "[", 
            RowBox[{"onenorm", "[", 
             RowBox[{"subsets", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}]}]}], "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"sortedwellnums", "=", 
       RowBox[{"Sort", "[", "wellnums", "]"}]}], ";", "\[IndentingNewLine]", 
      "sortedwellnums"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.973070713612646*^9, 3.973070837700122*^9}, {

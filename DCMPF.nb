Cell[TextData[{
 "From the unitarity condition, with the lowest order error ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "E_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43fda72a-78f9-4730-947f-553eb402d4f0"],
 ". We can represent error operator with using the lower order errors."
}], "Text",
 CellChangeTimes->{{3.9700861125079937`*^9, 
  3.9700861631338*^9}},ExpressionUUID->"88bbb018-1f29-4f68-9e0e-f791e41fa8ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"LieTrotterErrorUniRel", "[", "k_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"k", ">=", "4"}], ",", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"q", "!"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}], "**", 
             RowBox[{"Dagger", "[", 
              RowBox[{"A", "[", 
               RowBox[{"k", "-", "q"}], "]"}], "]"}]}]}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}], "**", 
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}]}]}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "0", ",", 
          RowBox[{"k", "-", "2"}]}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"A", "[", "q", "]"}], "**", 
         RowBox[{"Dagger", "[", 
          RowBox[{"A", "[", 
           RowBox[{"k", "-", "q"}], "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "2", ",", 
          RowBox[{"k", "-", "2"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"q", "!"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 

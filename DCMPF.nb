Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"wellcondsetscount", "[", 
    RowBox[{"thresh_", ",", "maxsub_", ",", "maxnum_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "subs", ",", "i", ",", "ii", ",", "j", ",", "deti", ",", "mn", ",", 
       "break", ",", "wellnums", ",", "sortedwellnums"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"wellnums", "=", 
       RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "maxnum"}], ",", 
        RowBox[{"i", "++"}], ",", " ", 
        RowBox[{
         RowBox[{"wellnums", "[", "i", "]"}], "=", "0"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mn", "=", "maxnum"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Label", "[", "deti", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"mn", "==", "1"}], ",", " ", 
        RowBox[{"Goto", "[", "break", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"wellnums", "[", "mn", "]"}], ">", "0"}], ",", " ", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"mn", "--"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Goto", "[", "deti", "]"}]}]}], "\[IndentingNewLine]", "]"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"ii", "=", 
         RowBox[{"Min", "[", 
          RowBox[{"mn", ",", "maxsub"}], "]"}]}], ",", 
        RowBox[{"ii", ">=", "1"}], ",", 
        RowBox[{"ii", "--"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"subs", "=", 
          RowBox[{"Subsets", "[", 
           RowBox[{
            RowBox[{"Range", "[", "mn", "]"}], ",", 
            RowBox[{"{", "ii", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"j", "=", "1"}], ",", 
           RowBox[{
            RowBox[{"j", "<=", 
             RowBox[{"Length", "[", "subs", "]"}]}], "&&", 
            RowBox[{
             RowBox[{"wellnums", "[", "ii", "]"}], "==", "0"}]}], ",", 
           RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"onenorm", "[", 
                  RowBox[{"subs", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "]"}], "]"}], "<", 
                "thresh"}], " ", "&&", " ", 
               RowBox[{
                RowBox[{"wellnums", "[", 
                 RowBox[{"subs", "[", 
                  RowBox[{"[", 
                   RowBox[{"j", ",", 
                    RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}], "==", "0"}]}], 
              ",", " ", 
              RowBox[{
               RowBox[{"wellnums", "[", 
                RowBox[{"subs", "[", 
                 RowBox[{"[", 
                  RowBox[{"j", ",", 
                   RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}], "=", "ii"}]}], 
             "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"wellnums", "[", "mn", "]"}], ">", "0"}], ",", " ", 
           "Break"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"mn", "--"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Goto", "[", "deti", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Label", "[", "break", "]"}], ";", "\[IndentingNewLine]", 
      "wellnums"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.988358478329644*^9, 3.988358498569107*^9}, {

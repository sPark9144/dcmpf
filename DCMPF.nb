Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Hamiltonian", " ", 
    RowBox[{"(", "H", ")"}], " ", "and", " ", "error", " ", 
    RowBox[{"(", "A", ")"}], " ", "descriptions"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Time", " ", "evolution", " ", "operator", " ", "in", " ", "H"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TruncatedTimeEvolutionH", "[", 
      RowBox[{"mult_", ",", "t_", ",", "h_", ",", " ", "order_"}], "]"}], ":=", 
     RowBox[{"1", "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"n", "!"}]], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "I"}], " ", "t", " ", "mult"}], ")"}], "^", "n"}], " ", 
         RowBox[{"Multiply", "@@", 
          RowBox[{"Table", "[", 
           RowBox[{"h", ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Trotter", " ", "operator", " ", "in", " ", "H", " ", "and", " ", "A", " ",
      "terms"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"etrunc", "[", 
      RowBox[{
      "mult_", ",", "t_", ",", " ", "a_", ",", " ", "orderi_", ",", 
       "orderf_"}], "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", " ", "mult"}], ")"}], "^", "n"}], " ", 
        RowBox[{"a", "[", "n", "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", "orderi", ",", "orderf"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"etruncd", "[", 
      RowBox[{
      "mult_", ",", "t_", ",", " ", "a_", ",", " ", "orderi_", ",", 
       "orderf_"}], "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", " ", "mult"}], ")"}], "^", "n"}], " ", 
        RowBox[{"Dagger", "[", 
         RowBox[{"a", "[", "n", "]"}], "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", "orderi", ",", "orderf"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TrotterErrorH", "[", 
      RowBox[{
      "mult_", ",", "t_", ",", " ", "h_", ",", " ", "a_", ",", " ", "orderi_",
        ",", "orderf_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"TruncatedTimeEvolutionH", "[", 
       RowBox[{"mult", ",", "t", ",", "h", ",", "orderf"}], "]"}], "+", 
      RowBox[{"etrunc", "[", 
       RowBox[{"mult", ",", "t", ",", "a", ",", "orderi", ",", "orderf"}], 
       "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TrotterErrorHD", "[", 
      RowBox[{
      "mult_", ",", "t_", ",", "h_", ",", "a_", ",", " ", "orderi_", ",", 
       "orderf_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"TruncatedTimeEvolutionH", "[", 
       RowBox[{
        RowBox[{"-", "mult"}], ",", "t", ",", "h", ",", "orderf"}], "]"}], "+", 
      RowBox[{"etruncd", "[", 
       RowBox[{"mult", ",", "t", ",", "a", ",", "orderi", ",", "orderf"}], 
       "]"}]}]}], ";"}]}]}]], "Input",

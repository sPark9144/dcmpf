Cell[TextData[{
 "For the second order formula, we can additionally implement the symmetric \
condition such that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["E", "TI"], 
          StyleBox["k", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", "-1", ")"}], 
          StyleBox["k", "TI"]], 
         SubsuperscriptBox[
          StyleBox["E", "TI"], 
          StyleBox["k", "TI"], "\[Dagger]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "E_k=(-1)^k E_k^\\dagger", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "810bc614-490f-46cc-ba4d-dbdda9c63e94"]
}], "Text",

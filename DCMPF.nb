Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MPF1", "[", 
     RowBox[{
      RowBox[{"exp_", "?", "ListQ"}], ",", " ", "init_", ",", " ", "obs_", ",",
       " ", "time_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "opslist", ",", "statlist", ",", "expeclist", ",", "vander", ",", 
        "MPFcoeff", ",", "res"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"opslist", "=", " ", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"LieTrotter", "[", 
           RowBox[{
            RowBox[{"exp", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", " ", "time"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "exp", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"statlist", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"opslist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ")"}], ".", "init"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "exp", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"expeclist", " ", "=", " ", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Conjugate", "[", 
            RowBox[{"statlist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}], ".", "obs", ".", 
           RowBox[{"(", 
            RowBox[{"statlist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "exp", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vander", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"Inverse", "[", 
          RowBox[{"VandermondeMatrix", "[", 

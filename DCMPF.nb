Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "0"}], ",", 
   RowBox[{"i", "<=", "alup"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"errel", "[", 
      RowBox[{"al", "+", "i"}], "]"}], "=", 
     RowBox[{"TrotterErrorUniRel", "[", 
      RowBox[{
       RowBox[{"al", "+", "i"}], ",", "al"}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"errelsimp", "[", 
      RowBox[{"al", "+", "i"}], "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"errel", "[", 
        RowBox[{"al", "+", "i"}], "]"}], "/.", 
       RowBox[{"Join", "@@", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"cond1", "[", 
           RowBox[{"al", "+", "j"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "0", ",", 
            RowBox[{"i", "-", "1"}]}], "}"}]}], "]"}]}]}], "//", 
      "ExpandAll"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"errelmod", "[", 
      RowBox[{"al", "+", "i"}], "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Dagger", "[", 
        RowBox[{"A", "[", 
         RowBox[{"al", "+", "i"}], "]"}], "]"}], "-", 
       RowBox[{"errelsimp", "[", 
        RowBox[{"al", "+", "i"}], "]"}]}], "//", "ExpandAll"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"cond1", "[", 
      RowBox[{"al", "+", "i"}], "]"}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Dagger", "[", 
        RowBox[{"A", "[", 
         RowBox[{"al", "+", "i"}], "]"}], "]"}], "->", 
       RowBox[{"errelmod", "[", 
        RowBox[{"al", "+", "i"}], "]"}]}], "}"}]}], ";"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.971215117051495*^9, 3.971215290060869*^9}, {
  3.971215327533639*^9, 3.971215368917677*^9}},
 CellLabel->
  "In[463]:=",ExpressionUUID->"6da6a603-2a01-4e5d-9d83-e7a7cbecedae"],

Cell[BoxData[

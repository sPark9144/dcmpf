          RowBox[{
           RowBox[{
            RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"k", "-", "q"}], "]"}], "**", 
            RowBox[{"Multiply", "@@", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"H", ",", "q"}], "]"}]}]}]}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"q", ",", "0", ",", 
         RowBox[{"k", "-", "3"}]}], "}"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SuzukiTrotterErrorUniRelReverse", "[", "k_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"k", ">=", "6"}], ",", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"q", "!"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", "I", ")"}], "^", "q"}], "  ", 
            RowBox[{
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}], "**", 
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}]}]}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"k", "-", "q"}], ")"}]}], " ", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}], "**", 

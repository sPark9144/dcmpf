   3.9585594852771072`*^9}, {3.958595554070212*^9, 3.958595601732079*^9}, {
   3.958595635992181*^9, 3.958595657246996*^9}, {3.958595768082528*^9, 
   3.958595778396183*^9}, {3.958596051153013*^9, 3.958596063909048*^9}, {
   3.958695765339933*^9, 3.9586957668330507`*^9}, 3.9592043363076887`*^9, {
   3.9685261286357822`*^9, 3.968526142382484*^9}, {3.968527148305505*^9, 

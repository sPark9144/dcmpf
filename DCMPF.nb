          RowBox[{"k", "-", "3"}]}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", 
          RowBox[{"(", "q", ")"}]}], " ", 
         RowBox[{
          RowBox[{"A", "[", "q", "]"}], "**", 
          RowBox[{"A", "[", 
           RowBox[{"k", "-", "q"}], "]"}]}]}], ",", 
        RowBox[{"{", 

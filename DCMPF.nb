  3.970086201481505*^9}},ExpressionUUID->"fa80fce9-3280-44e4-9987-\
40b1bae803d7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SuzukiTrotterErrorUniRel", "[", "k_", "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"k", ">=", "6"}], ",", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"q", "!"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"k", "-", "q"}], ")"}]}], " ", 
            RowBox[{
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}], "**", 
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}]}]}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}], "**", 
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}]}]}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "0", ",", 
          RowBox[{"k", "-", "3"}]}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"k", "-", "q"}], ")"}]}], " ", 
         RowBox[{
          RowBox[{"A", "[", "q", "]"}], "**", 
          RowBox[{"A", "[", 
           RowBox[{"k", "-", "q"}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "3", ",", 
          RowBox[{"k", "-", "3"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"q", "!"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 

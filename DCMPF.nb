Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Expansions", " ", "of", " ", "the", " ", "time", " ", "evolution", " ", 
    "operator", " ", "and", " ", "Trotter", " ", "formula"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Simple", " ", "truncated", " ", "exponential", " ", "and", " ", "time", " ",
      "evolution", " ", 
     RowBox[{"operator", ".", " ", 
      RowBox[{"TruncatedTimeEvolution", "[", 
       RowBox[{
       "mult", ",", " ", "t", ",", " ", "A", ",", " ", "l", ",", " ", 
        "order"}], "]"}]}]}], "=", 
    RowBox[{"Exp", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "i"}], " ", "mult", "*", "t", "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"A_l", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"A_l", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "+"}], "..."}], ")"}]}], ")"}], " ",
      "up", " ", "to", " ", 
     RowBox[{"t", "^", "order"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TruncatedExp", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"order_", "?", "IntegerQ"}]}], "]"}], ":=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"n", "!"}]], "*", 
        RowBox[{"Multiply", "@@", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"x", ",", "n"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "0", ",", "order"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TruncatedTimeEvolution", "[", 
     RowBox[{"mult_", ",", "t_", ",", "A_", ",", 
      RowBox[{"l_", "?", "ListQ"}], ",", 
      RowBox[{"order_", "?", "IntegerQ"}]}], "]"}], ":=", 
    RowBox[{"TruncatedExp", "[", 
     RowBox[{
      RowBox[{"Plus", "@@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"mult", "**", "t", "**", 
           RowBox[{"A", "[", "#", "]"}]}], "&"}], "/@", "l"}], ")"}]}], ",", 
      "order"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Trotter", "[", 
       RowBox[{
       "mult", ",", " ", "t", ",", " ", "A", ",", " ", "l", ",", " ", "order",
         ",", " ", "upto"}], "]"}], " ", "gives", " ", 
      RowBox[{"(", 
       RowBox[{"order", "=", 
        RowBox[{"first", "-", " ", 
         RowBox[{"and", " ", "second"}], "-"}]}], ")"}], " ", "order", " ", 
      "Trotter", " ", "formula", " ", "with", " ", "mult", "*", "t", " ", 
      "time"}], ",", " ", 
     RowBox[{"truncated", " ", "in", " ", "the", " ", "order", " ", "of", " ", 
      RowBox[{"t", "^", "upto"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Trotter", "[", 
      RowBox[{"mult_", ",", "t_", ",", "A_", ",", 
       RowBox[{"l_", "?", "ListQ"}], ",", "order_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"inputlist", ",", "trott", ",", " ", "r", ",", " ", "coeff"}],
         "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Let", "[", 
         RowBox[{"Real", ",", "t"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Let", "[", 
         RowBox[{"NonCommutative", ",", "A"}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"order", "==", "1"}], ",", " ", 
          RowBox[{"inputlist", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"TruncatedExp", "[", 
              RowBox[{
               RowBox[{"mult", "**", "t", "**", 
                RowBox[{"A", "[", "#", "]"}]}], ",", " ", "upto"}], "]"}], 
             "&"}], "/@", "l"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"order", "==", "2"}], ",", " ", 
            RowBox[{"inputlist", "=", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"TruncatedExp", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"mult", "**", "t", "**", 
                    RowBox[{"A", "[", "#", "]"}]}], "/", "2"}], ",", " ", 
                   "upto"}], "]"}], "&"}], "/@", "l"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"TruncatedExp", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"mult", "**", "t", "**", 
                    RowBox[{"A", "[", "#", "]"}]}], "/", "2"}], ",", "upto"}],
                   "]"}], "&"}], "/@", 
                RowBox[{"Reverse", "[", "l", "]"}]}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"inputlist", "=", 
             RowBox[{"{", "1", "}"}]}]}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"trott", "=", 
         RowBox[{"OrderSuppressMultiply", "[", 
          RowBox[{"inputlist", ",", "t", ",", "upto"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "trott"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Terms"}]}], " ", "gives", " ", "each", " ", "terms", " ",
       "in", " ", "the", " ", "original", " ", 
      RowBox[{"funtion", " ", "--"}]}], "-", " ", 
     RowBox[{"in", " ", "order", " ", "of", " ", "t"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TrotterTerms", "[", 
      RowBox[{"mult_", ",", "t_", ",", "A_", ",", 
       RowBox[{"l_", "?", "ListQ"}], ",", "order_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"trott", ",", "coeff"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"trott", "=", 
         RowBox[{"Trotter", "[", 
          RowBox[{
          "mult", ",", "t", ",", "A", ",", "l", ",", "order", ",", "upto"}], 
          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"coeff", "=", 
         RowBox[{"CoefficientList", "[", 
          RowBox[{"trott", ",", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"coeff", "[", 
         RowBox[{"[", 
          RowBox[{";;", 
           RowBox[{"upto", "+", "1"}]}], "]"}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
      "Trotter", " ", "Error", " ", "gives", " ", "the", " ", "error", " ", 
       "of", " ", "single"}], "-", 
      RowBox[{
      "step", " ", "Trotter", " ", "formula", " ", "compared", " ", "to", " ",
        "the", " ", "time", " ", "evolution", " ", "operator"}]}], ",", " ", 
     RowBox[{"upto", " ", "the", " ", "order", " ", "of", " ", 
      RowBox[{"t", "^", "upto"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TrotterError", "[", 
      RowBox[{"mult_", ",", "t_", ",", "A_", ",", 
       RowBox[{"l_", "?", "ListQ"}], ",", "order_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"trott", ",", " ", "error"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"trott", "=", 
         RowBox[{"Trotter", "[", 
          RowBox[{
          "mult", ",", "t", ",", "A", ",", "l", ",", "order", ",", "upto"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"error", "=", 
         RowBox[{"trott", "-", " ", 
          RowBox[{"TruncatedExp", "[", 
           RowBox[{
            RowBox[{"Plus", "@@", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"mult", "**", "t", "**", 
                 RowBox[{"A", "[", "#", "]"}]}], "&"}], "/@", "l"}], ")"}]}], 
            ",", "upto"}], "]"}]}]}], ";", "\[IndentingNewLine]", "error"}]}],
       "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TrotterErrorTerms", "[", 
      RowBox[{"mult_", ",", "t_", ",", "A_", ",", 
       RowBox[{"l_", "?", "ListQ"}], ",", "order_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", " ", 
        RowBox[{"error", ",", "coeff"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"error", "=", 
         RowBox[{"TrotterError", "[", 
          RowBox[{
          "mult", ",", "t", ",", "A", ",", "l", ",", "order", ",", "upto"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"coeff", "=", 
         RowBox[{"CoefficientList", "[", 
          RowBox[{"error", ",", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"coeff", "[", 
         RowBox[{"[", 
          RowBox[{";;", 
           RowBox[{"upto", "+", "1"}]}], "]"}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 

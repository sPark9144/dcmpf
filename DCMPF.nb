   TemplateBox[<|
    "boxes" -> FormBox["\[Alpha]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\alpha", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0eeba2b8-e79b-452c-a236-a88c4b175be8"],
 "-order (no additional condition) Trotter"
}], "Text",
 CellChangeTimes->{{3.971215495140366*^9, 3.971215540678747*^9}, {
  3.971215627707273*^9, 
  3.971215627872604*^9}},ExpressionUUID->"c7ca8a02-c378-4e08-8c7f-\
e9d6f2101ff9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TrotterErrorUniRel", "[", 
    RowBox[{"k_", ",", "al_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"k", ">=", 
      RowBox[{"2", "al"}]}], ",", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"q", "!"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}], "**", 
             RowBox[{"Dagger", "[", 
              RowBox[{"A", "[", 
               RowBox[{"k", "-", "q"}], "]"}], "]"}]}]}], "+", 
           RowBox[{
            RowBox[{
             RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
            RowBox[{
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}], "**", 
             RowBox[{"Multiply", "@@", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"H", ",", "q"}], "]"}]}]}]}]}], ")"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "0", ",", 
          RowBox[{"k", "-", "al"}]}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"A", "[", "q", "]"}], "**", 
         RowBox[{"Dagger", "[", 
          RowBox[{"A", "[", 
           RowBox[{"k", "-", "q"}], "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"q", ",", "al", ",", 
          RowBox[{"k", "-", "al"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", 
         RowBox[{"q", "!"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "I"}], ")"}], "^", "q"}], " ", 
           RowBox[{
            RowBox[{"Multiply", "@@", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"H", ",", "q"}], "]"}]}], "**", 
            RowBox[{"Dagger", "[", 
             RowBox[{"A", "[", 
              RowBox[{"k", "-", "q"}], "]"}], "]"}]}]}], "+", 
          RowBox[{
           RowBox[{
            RowBox[{"(", "I", ")"}], "^", "q"}], " ", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"k", "-", "q"}], "]"}], "**", 
            RowBox[{"Multiply", "@@", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"H", ",", "q"}], "]"}]}]}]}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"q", ",", "0", ",", 
         RowBox[{"k", "-", "al"}]}], "}"}]}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.970037526652514*^9, 3.970037739013739*^9}, {
   3.970037772549781*^9, 3.970037840395357*^9}, {3.970038152307259*^9, 
   3.9700382354905987`*^9}, {3.9700860248083143`*^9, 3.9700860295802917`*^9}, 

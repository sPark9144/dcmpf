Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Multiplication", " ", "with", " ", "higher", " ", "order", " ", 
     "suppression"}], ",", " ", 
    RowBox[{
    "improving", " ", "memory", " ", "consumption", " ", "and", " ", 
     "efficiency"}]}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"OrderSuppressMultiply", "[", 
        RowBox[{"input", ",", " ", "var", ",", " ", "upto"}], "]"}], " ", 
       "gives", " ", 
       RowBox[{
        RowBox[{"input", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "**", 
        RowBox[{"input", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "**", 
        RowBox[{"input", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "**"}]}], "..."}], " ", "with", " ", 
     "truncated", " ", "terms", " ", "in", " ", "order", " ", "of", " ", 
     RowBox[{"var", "^", "upto"}]}], ",", " ", 
    RowBox[{"for", " ", "each", " ", "multiplication"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"OrderSuppressMultiply", "[", 
      RowBox[{
       RowBox[{"input_", "?", "ListQ"}], ",", "var_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "res"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"r", "[", "1", "]"}], "=", 
         RowBox[{"input", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"r", "[", "j_", "]"}], ":=", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Array", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"var", "^", 
                RowBox[{"(", 
                 RowBox[{"#", "-", "1"}], ")"}]}], "&"}], ",", 
              RowBox[{"upto", "+", "1"}]}], "]"}], "*", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"Multiply", "[", 
               RowBox[{
                RowBox[{"r", "[", 
                 RowBox[{"j", "-", "1"}], "]"}], ",", 
                RowBox[{"input", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", "var", ",", 
              RowBox[{"upto", "+", "1"}]}], "]"}]}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"r", "[", 
          RowBox[{"Length", "[", "input", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "res"}]}], "\[IndentingNewLine]", "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"OrderSuppressPower", "[", 
       RowBox[{
       "input", ",", " ", "var", ",", " ", "power", ",", " ", "upto"}], "]"}],
       " ", "gives", " ", 
      RowBox[{"input", "^", "power"}], " ", "with", " ", "truncated", " ", 
      "terms", " ", "in", " ", "order", " ", "of", " ", 
      RowBox[{"var", "^", "upto"}]}], ",", " ", 
     RowBox[{"for", " ", "each", " ", "multiplication"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"OrderSuppressPower", "[", 
      RowBox[{"input_", ",", "var_", ",", "power_", ",", "upto_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "res"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"r", "[", "1", "]"}], "=", "input"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"r", "[", "j_", "]"}], ":=", 
         RowBox[{"Plus", "@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Array", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"var", "^", 
                RowBox[{"(", 
                 RowBox[{"#", "-", "1"}], ")"}]}], "&"}], ",", 
              RowBox[{"upto", "+", "1"}]}], "]"}], "*", 
            RowBox[{"CoefficientList", "[", 
             RowBox[{
              RowBox[{"Multiply", "[", 
               RowBox[{
                RowBox[{"r", "[", 
                 RowBox[{"j", "-", "1"}], "]"}], ",", "input"}], "]"}], ",", 
              "var", ",", 
              RowBox[{"upto", "+", "1"}]}], "]"}]}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"r", "[", "power", "]"}]}], ";", "\[IndentingNewLine]", 
        "res"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.95855821527337*^9, 3.958558304940896*^9}, {
   3.9585585710897303`*^9, 3.958558636014539*^9}, {3.958558700731183*^9, 
   3.958558711013401*^9}, {3.958558915055361*^9, 3.95855892108136*^9}, {
